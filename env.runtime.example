# Iron Council runtime environment contract
# Copy this to a private file (for example `.env.runtime`) for shared or hosted operation.
# Point the server launcher at that file with `IRON_COUNCIL_ENV_FILE=.env.runtime`.

# Required for any DB-backed runtime.
DATABASE_URL=postgresql+psycopg://iron_council:replace-me@db-host:5432/iron_council
IRON_COUNCIL_MATCH_REGISTRY_BACKEND=db

# Required when authenticated human HTTP or websocket flows are enabled.
HUMAN_JWT_SECRET=replace-with-real-secret
HUMAN_JWT_ISSUER=https://example.supabase.co/auth/v1
HUMAN_JWT_AUDIENCE=authenticated
HUMAN_JWT_REQUIRED_ROLE=authenticated

# Optional browser-origin allowlist for the API process.
IRON_COUNCIL_BROWSER_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional launcher-only knobs consumed by ./scripts/runtime-control.sh.
IRON_COUNCIL_SERVER_HOST=127.0.0.1
IRON_COUNCIL_SERVER_PORT=8000
IRON_COUNCIL_SERVER_RELOAD=false
IRON_COUNCIL_CLIENT_HOST=127.0.0.1
IRON_COUNCIL_CLIENT_PORT=3000

# Local/dev-only knob for parallel worktree database lanes. Leave unset in shared/hosted runs.
# IRON_COUNCIL_DB_LANE=local

# The Next.js client does not require its own checked-in environment variables today.
# Browser sessions store the API base URL and optional human bearer token in local storage.
